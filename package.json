{
  "name": "memoryoss-smithery-bridge",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "module": "smithery/index.ts",
  "scripts": {
    "smithery:build": "smithery mcp build --transport stdio",
    "smithery:publish": "smithery mcp publish --from-build .smithery/stdio --name memoryosscom/memoryoss",
    "smithery:build-http": "esbuild smithery/http.ts --bundle --platform=node --format=cjs --outfile=.smithery/http/server.cjs",
    "smithery:publish-url": "smithery mcp publish https://memoryoss.com/mcp --name memoryosscom/memoryoss --config-schema smithery/url-config.schema.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@smithery/sdk": "^4.3.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@smithery/cli": "^4.7.4",
    "esbuild": "^0.27.4"
  }
}
