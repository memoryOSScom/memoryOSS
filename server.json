{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.memoryOSScom/memoryoss",
  "title": "memoryOSS",
  "description": "Persistent memory for AI agents with local MCP tools and hybrid recall.",
  "repository": {
    "url": "https://github.com/memoryOSScom/memoryOSS",
    "source": "github"
  },
  "websiteUrl": "https://memoryoss.com",
  "version": "0.2.0",
  "icons": [
    {
      "src": "https://memoryoss.com/favicon-32.png",
      "sizes": [
        "32x32"
      ],
      "mimeType": "image/png"
    }
  ],
  "packages": [
    {
      "registryType": "oci",
      "identifier": "ghcr.io/memoryosscom/memoryoss:0.2.0",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "_meta": {
    "io.github.memoryOSScom/anthropic-local-mcp": {
      "submissionPath": "local-mcp-server",
      "readinessStatus": "documented",
      "privacyPolicyUrl": "https://memoryoss.com/datenschutz.html",
      "support": {
        "email": "hello@memoryoss.com",
        "issuesUrl": "https://github.com/memoryOSScom/memoryOSS/issues"
      },
      "desktopInstall": {
        "command": "memoryoss",
        "args": [
          "-c",
          "${user_config.config_path}",
          "mcp-server"
        ],
        "docsUrl": "https://github.com/memoryOSScom/memoryOSS#anthropic-local-mcp-readiness"
      },
      "manifestTemplate": {
        "manifest_version": "0.3",
        "server": {
          "type": "binary",
          "entry_point": "memoryoss",
          "mcp_config": {
            "command": "memoryoss",
            "args": [
              "-c",
              "${user_config.config_path}",
              "mcp-server"
            ]
          }
        },
        "privacy_policies": [
          "https://memoryoss.com/datenschutz.html"
        ],
        "support": "https://github.com/memoryOSScom/memoryOSS/issues",
        "compatibility": {
          "platforms": [
            "darwin",
            "linux"
          ]
        }
      },
      "toolAnnotations": [
        {
          "name": "memoryoss_recall",
          "title": "Recall Relevant Memories",
          "annotations": {
            "readOnlyHint": true,
            "destructiveHint": false
          }
        },
        {
          "name": "memoryoss_store",
          "title": "Store New Memory",
          "annotations": {
            "readOnlyHint": false,
            "destructiveHint": true
          }
        },
        {
          "name": "memoryoss_update",
          "title": "Update Existing Memory",
          "annotations": {
            "readOnlyHint": false,
            "destructiveHint": true
          }
        },
        {
          "name": "memoryoss_forget",
          "title": "Delete Stored Memory",
          "annotations": {
            "readOnlyHint": false,
            "destructiveHint": true
          }
        }
      ],
      "releaseArtifacts": [
        "memoryoss-mcp-server.json",
        "memoryoss-mcp-manifest.json",
        "memoryoss-mcp-claude-desktop.json",
        "memoryoss-mcp-tools.json",
        "memoryoss-mcp-package.json"
      ],
      "governance": {
        "runtimeContract": {
          "current": "memoryoss.runtime.v1alpha1",
          "compatibilityWindow": "N/N-1/N-2",
          "deprecationPolicy": "Publish fixture-backed notice before removal; keep at least N/N-1/N-2 import and reader compatibility during the supported window.",
          "conformanceFixtures": "https://github.com/memoryOSScom/memoryOSS/tree/main/conformance"
        },
        "bundleFormat": {
          "current": "memoryoss.bundle.v1alpha1",
          "readerRequirement": "Artifacts must remain openable through the published reader during the support window.",
          "deprecationPolicy": "Ship replacement fixture plus reader compatibility before format removal."
        },
        "signerRegistry": {
          "catalogSchema": "memoryoss.trust.catalog.v1alpha1",
          "exportPath": "/v1/admin/trust/catalog/export",
          "importPath": "/v1/admin/trust/catalog/import",
          "pinPath": "/v1/admin/trust/pin",
          "unpinPath": "/v1/admin/trust/unpin"
        },
        "interop": {
          "submissionPath": "Conformance fixtures + canonical MCP metadata bundle + portable signer catalogs",
          "thirdPartyPolicy": "Third-party runtimes may implement the published contract and submit fixtures/catalog metadata without requiring private coordination.",
          "vendorLockIn": "Versioned fixtures, portable catalogs, and explicit deprecation windows are the compatibility boundary."
        }
      },
      "submissionGaps": [
        "Live tools/list annotations are blocked on rmcp 0.1.5, which does not yet serialize title/readOnlyHint/destructiveHint fields.",
        "Portable .mcpb bundling is still separate follow-up work; the release pipeline ships canonical JSON metadata artifacts instead."
      ]
    }
  }
}
